# =============================================================================
# T.N. Memorial Public School Digital Platform
# deployment/docker/.env.example
# Docker environment variable template
# Authority: .github/AGENT.md (Section 4.1 — Docker Governance)
#
# IMPORTANT: Copy this file to .env and fill in real values.
#            NEVER commit .env to the repository.
#            .env is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="T.N. Memorial Public School Digital Platform"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# ---------------------------------------------------------------------------
# Database — MySQL 8
# Used by: mysql container, php container, phpmyadmin container
# ---------------------------------------------------------------------------
DB_NAME=tnm_school_platform
DB_USER=tnm_user
DB_PASSWORD=change_this_strong_password
MYSQL_ROOT_PASSWORD=change_this_root_password

# ---------------------------------------------------------------------------
# Next.js frontend — API base URL
# Used by: website container, erp container
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost/api

# ---------------------------------------------------------------------------
# Mail (optional — not required for local development)
# ---------------------------------------------------------------------------
MAIL_HOST=smtp.localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tnmschool.example.com
MAIL_FROM_NAME="T.N. Memorial Public School"

# ---------------------------------------------------------------------------
# JWT (used by PHP backend Auth module)
# ---------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_characters
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_PATH=./storage/cache
CACHE_TTL=300

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
TZ=UTC